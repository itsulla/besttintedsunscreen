---
interface Props {
  href: string;
  label?: string;
  variant?: "primary" | "secondary";
  size?: "sm" | "md";
}

const {
  href,
  label = "Check Price",
  variant = "primary",
  size = "md",
} = Astro.props;

const base =
  "inline-flex items-center gap-1.5 font-medium rounded-full transition-all whitespace-nowrap";
const sizes = {
  sm: "text-xs px-3 py-1.5",
  md: "text-sm px-4 py-2",
};
const variants = {
  primary:
    "bg-ink-900 text-cream-50 hover:bg-sun-700 hover:scale-[1.02] shadow-sm",
  secondary:
    "bg-sun-100 text-sun-800 hover:bg-sun-200 border border-sun-200/50",
};
---

<a
  href={href}
  target="_blank"
  rel="nofollow sponsored noopener"
  class={`${base} ${sizes[size]} ${variants[variant]}`}
>
  {label}
  <span aria-hidden="true">→</span>
</a>
