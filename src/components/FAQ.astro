---
interface Item {
  q: string;
  a: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<div class="space-y-3">
  {
    items.map((item, i) => (
      <details
        class="group bg-white border border-ink-900/8 rounded-xl overflow-hidden"
        open={i === 0}
      >
        <summary class="cursor-pointer px-5 py-4 flex items-center justify-between font-display font-semibold text-ink-900 list-none">
          <span class="pr-4">{item.q}</span>
          <span class="text-sun-600 text-lg transition-transform group-open:rotate-45 shrink-0">
            +
          </span>
        </summary>
        <div class="px-5 pb-5 pt-0 text-ink-600 leading-relaxed" set:html={item.a} />
      </details>
    ))
  }
</div>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
