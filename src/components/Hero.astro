---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  updated?: string;
}
const { eyebrow, title, subtitle, updated } = Astro.props;
---

<section class="relative overflow-hidden">
  <!-- Sun ray background accent -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[900px] rounded-full opacity-[0.07] pointer-events-none"
    style="background: radial-gradient(circle at center, #F18F1C 0%, transparent 55%);"
  >
  </div>

  <div class="relative max-w-page mx-auto px-5 md:px-8 pt-16 md:pt-24 pb-8 md:pb-12">
    {
      eyebrow && (
        <div class="flex items-center gap-2 mb-5">
          <span class="w-6 h-px bg-sun-600" />
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-sun-700">
            {eyebrow}
          </span>
        </div>
      )
    }

    <h1
      class="font-display font-bold text-ink-900 text-[clamp(2.25rem,5.5vw,4.5rem)] leading-[1.02] tracking-tightest max-w-4xl"
    >
      {title}
    </h1>

    <p
      class="mt-6 text-lg md:text-xl text-ink-600 leading-relaxed max-w-2xl"
    >
      {subtitle}
    </p>

    {
      updated && (
        <div class="mt-8 flex items-center gap-2 text-sm text-ink-400">
          <span class="w-1.5 h-1.5 rounded-full bg-sun-500 animate-pulse" />
          <span>Last updated {updated}</span>
        </div>
      )
    }
  </div>
</section>
