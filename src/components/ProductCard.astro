---
import AffiliateButton from "./AffiliateButton.astro";

interface Props {
  rank: number;
  name: string;
  brand: string;
  tagline: string;
  price: string;
  spf: string;
  finish: string;
  bestFor: string;
  skinType: string;
  pros: string[];
  cons: string[];
  image?: string; // filename under /products/, e.g. "boj-aqua-fresh.jpg"
  amazonUrl?: string;
  stylekoreanUrl?: string;
  reviewUrl?: string;
  highlight?: "editors-pick" | "budget-pick" | "surge";
}

const {
  rank,
  name,
  brand,
  tagline,
  price,
  spf,
  finish,
  bestFor,
  skinType,
  pros,
  cons,
  image,
  amazonUrl = "#",
  stylekoreanUrl,
  reviewUrl,
  highlight,
} = Astro.props;

const imgSrc = image ? `/products/${image}` : null;

const highlightLabels = {
  "editors-pick": { label: "Editor's Pick", color: "bg-sun-500 text-white" },
  "budget-pick": { label: "Budget Pick", color: "bg-ink-700 text-cream-50" },
  surge: { label: "Surging", color: "bg-sun-100 text-sun-800 border border-sun-300" },
};

const hl = highlight ? highlightLabels[highlight] : null;
---

<article
  id={`rank-${rank}`}
  class="group relative bg-white border border-ink-900/8 rounded-2xl overflow-hidden shadow-[0_1px_0_rgba(26,24,20,0.03),0_4px_12px_rgba(26,24,20,0.04)] hover:shadow-[0_2px_0_rgba(26,24,20,0.05),0_12px_32px_rgba(26,24,20,0.08)] transition-all duration-300 scroll-mt-24"
>
  <div class:list={[imgSrc ? "md:grid md:grid-cols-[240px_1fr]" : ""]}>
    <!-- Product image (left column on desktop, top on mobile) -->
    {
      imgSrc && (
        <div class="relative bg-cream-100 border-b md:border-b-0 md:border-r border-ink-900/5 flex items-center justify-center p-8 md:p-6 min-h-[240px]">
          <img
            src={imgSrc}
            alt={`${brand} ${name}`}
            loading="lazy"
            class="max-w-full max-h-52 md:max-h-56 object-contain drop-shadow-sm"
            width="220"
            height="220"
          />
          {hl && (
            <span
              class={`absolute top-3 left-3 text-[10px] font-semibold uppercase tracking-wider px-2 py-1 rounded-full shadow-sm ${hl.color}`}
            >
              {hl.label}
            </span>
          )}
          <span class="absolute top-3 right-3 font-display text-2xl font-bold text-sun-600 tracking-tighter leading-none bg-cream-50 w-10 h-10 rounded-full flex items-center justify-center shadow-sm">
            #{rank}
          </span>
        </div>
      )
    }

    <!-- Content column -->
    <div class="p-6 md:p-7">
      {
        !imgSrc && (
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class="font-display text-3xl font-bold text-sun-600 tracking-tighter leading-none">
                #{rank}
              </span>
              {hl && (
                <span
                  class={`text-[10px] font-semibold uppercase tracking-wider px-2 py-1 rounded-full ${hl.color}`}
                >
                  {hl.label}
                </span>
              )}
            </div>
            <div class="text-right">
              <div class="text-xs text-ink-400 uppercase tracking-wider">Price</div>
              <div class="font-mono text-sm font-semibold text-ink-900">{price}</div>
            </div>
          </div>
        )
      }

      <!-- Name + brand -->
      <div class="mb-4">
        <div class="flex items-start justify-between gap-4 mb-1">
          <div class="text-xs font-semibold uppercase tracking-wider text-ink-500">
            {brand}
          </div>
          {
            imgSrc && (
              <div class="text-right shrink-0">
                <div class="text-[10px] text-ink-400 uppercase tracking-wider">
                  Price
                </div>
                <div class="font-mono text-sm font-semibold text-ink-900">
                  {price}
                </div>
              </div>
            )
          }
        </div>
        <h3 class="font-display text-2xl font-bold text-ink-900 leading-tight tracking-tight">
          {name}
        </h3>
        <p class="text-sm text-ink-600 mt-2 leading-relaxed">{tagline}</p>
      </div>

      <!-- Specs grid -->
      <div class="grid grid-cols-2 gap-3 mb-5 pt-4 border-t border-ink-900/5">
        <div>
          <div class="text-[10px] text-ink-400 uppercase tracking-wider mb-0.5">
            SPF
          </div>
          <div class="text-sm font-semibold text-ink-800">{spf}</div>
        </div>
        <div>
          <div class="text-[10px] text-ink-400 uppercase tracking-wider mb-0.5">
            Finish
          </div>
          <div class="text-sm font-semibold text-ink-800">{finish}</div>
        </div>
        <div>
          <div class="text-[10px] text-ink-400 uppercase tracking-wider mb-0.5">
            Best For
          </div>
          <div class="text-sm font-semibold text-ink-800">{bestFor}</div>
        </div>
        <div>
          <div class="text-[10px] text-ink-400 uppercase tracking-wider mb-0.5">
            Skin Type
          </div>
          <div class="text-sm font-semibold text-ink-800">{skinType}</div>
        </div>
      </div>

      <!-- Pros / cons -->
      <div class="grid md:grid-cols-2 gap-4 mb-5">
        <div>
          <div class="text-[10px] font-semibold uppercase tracking-wider text-ink-500 mb-2">
            What we love
          </div>
          <ul class="space-y-1">
            {
              pros.map((p) => (
                <li class="text-sm text-ink-700 flex gap-2">
                  <span class="text-sun-600 shrink-0">+</span>
                  <span>{p}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <div class="text-[10px] font-semibold uppercase tracking-wider text-ink-500 mb-2">
            Keep in mind
          </div>
          <ul class="space-y-1">
            {
              cons.map((c) => (
                <li class="text-sm text-ink-700 flex gap-2">
                  <span class="text-ink-400 shrink-0">−</span>
                  <span>{c}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- CTA row -->
      <div class="flex flex-wrap items-center gap-2 pt-4 border-t border-ink-900/5">
        <AffiliateButton href={amazonUrl} label="Buy on Amazon" variant="primary" />
        {
          stylekoreanUrl && (
            <AffiliateButton
              href={stylekoreanUrl}
              label="StyleKorean"
              variant="secondary"
            />
          )
        }
        {
          reviewUrl && (
            <a
              href={reviewUrl}
              class="text-sm font-medium text-sun-700 hover:text-sun-800 ml-auto"
            >
              Full review →
            </a>
          )
        }
      </div>
    </div>
  </div>
</article>
