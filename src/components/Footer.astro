---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-ink-900/10">
  <div class="max-w-page mx-auto px-5 md:px-8 py-12">
    <div class="grid md:grid-cols-5 gap-10 md:gap-6">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <span
            class="w-7 h-7 rounded-full bg-gradient-to-br from-sun-400 to-sun-600 shadow-sm"
          ></span>
          <span
            class="font-display text-lg font-bold tracking-tight text-ink-900 leading-none"
          >
            Best<span class="text-sun-600">Tinted</span>Sunscreen
          </span>
        </a>
        <p class="text-sm text-ink-500 leading-relaxed max-w-sm">
          Independent reviews of Korean and tinted mineral sunscreens.
          We test them on real skin, rank them honestly, and tell you where to
          buy the ones worth your money.
        </p>
      </div>

      <div>
        <h4 class="font-display font-semibold text-ink-900 text-sm mb-3">
          Reviews
        </h4>
        <ul class="space-y-2 text-sm text-ink-500">
          <li>
            <a
              href="/reviews/beauty-of-joseon-relief-sun-aqua-fresh/"
              class="hover:text-sun-700 transition-colors"
            >
              Beauty of Joseon Aqua-Fresh
            </a>
          </li>
          <li>
            <a
              href="/reviews/merit-the-uniform-tinted-mineral/"
              class="hover:text-sun-700 transition-colors"
            >
              Merit The Uniform
            </a>
          </li>
          <li>
            <a
              href="/compare/boj-aqua-fresh-vs-merit-uniform/"
              class="hover:text-sun-700 transition-colors"
            >
              BoJ vs Merit
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-semibold text-ink-900 text-sm mb-3">
          Guides
        </h4>
        <ul class="space-y-2 text-sm text-ink-500">
          <li>
            <a
              href="/guides/what-is-no-white-cast-sunscreen/"
              class="hover:text-sun-700 transition-colors"
            >
              No White Cast
            </a>
          </li>
          <li>
            <a
              href="/guides/best-korean-sunscreen-australia/"
              class="hover:text-sun-700 transition-colors"
            >
              Australia Edition
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-semibold text-ink-900 text-sm mb-3">
          Legal
        </h4>
        <ul class="space-y-2 text-sm text-ink-500">
          <li>
            <a
              href="/disclosure/"
              class="hover:text-sun-700 transition-colors"
            >
              Affiliate disclosure
            </a>
          </li>
          <li>
            <a href="/privacy/" class="hover:text-sun-700 transition-colors">
              Privacy policy
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-10 pt-6 border-t border-ink-900/5 flex flex-col md:flex-row md:items-center md:justify-between gap-3"
    >
      <p class="text-xs text-ink-400">
        © {year} Best Tinted Sunscreen. Independent editorial project.
      </p>
      <p class="text-xs text-ink-400 max-w-md md:text-right">
        Some links are affiliate links — if you buy through them we may earn a
        small commission at no extra cost to you. See our
        <a href="/disclosure/" class="underline hover:text-sun-700">
          full disclosure
        </a>
        .
      </p>
    </div>
  </div>
</footer>
