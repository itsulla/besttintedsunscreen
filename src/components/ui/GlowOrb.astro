---
interface Props {
  size?: number;
  color?: string;
  opacity?: number;
  class?: string;
  style?: string;
}
const {
  size    = 700,
  color   = "#E8B088",
  opacity = 0.35,
  class: clazz = "",
  style: extraStyle = "",
} = Astro.props;

const alphaHex = Math.round(opacity * 255).toString(16).padStart(2, "0");
---

<div
  class={`pointer-events-none absolute rounded-full ${clazz}`}
  style={`width:${size}px;height:${size}px;background:radial-gradient(circle,${color}${alphaHex} 0%,transparent 60%);${extraStyle}`}
></div>
