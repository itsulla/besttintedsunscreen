---
interface Props {
  color?: string;
  size?: number;
}
const { color = "#D4A15E", size = 14 } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  style="display:inline-block;vertical-align:middle"
>
  <path
    d="M12 2 L13.5 10.5 L22 12 L13.5 13.5 L12 22 L10.5 13.5 L2 12 L10.5 10.5 Z"
    fill={color}
  />
</svg>
