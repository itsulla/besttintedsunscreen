---
const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  currentPath === path || currentPath.startsWith(path + "/");

const links = [
  { label: "Reviews", href: "/reviews/" },
  { label: "Quiz",    href: "/quiz/" },
  { label: "Guides",  href: "/guides/" },
  { label: "About",   href: "/about/" },
];
---

<header class="relative z-50">
  <div class="max-w-glow mx-auto px-8 md:px-16 py-7 flex items-center justify-between">
    <!-- Wordmark + orb mark -->
    <a href="/" class="flex items-center gap-3 group">
      <div
        class="w-8 h-8 rounded-full flex-shrink-0"
        style="background:radial-gradient(circle at 30% 30%,#D4A15E,#E8B088)"
      ></div>
      <span class="text-sm tracking-[0.2em] font-medium text-glow-ink">
        besttintedsunscreen
      </span>
    </a>

    <!-- Nav links -->
    <nav class="hidden md:flex items-center gap-10 text-sm text-glow-muted">
      {links.map(({ label, href }) => (
        <a
          href={href}
          class={`transition-colors hover:text-glow-ink ${
            isActive(href) ? "text-glow-ink" : ""
          }`}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <a
      href="#newsletter"
      class="hidden md:inline-flex text-xs tracking-[0.2em] uppercase font-medium px-6 py-3 rounded-full transition-opacity hover:opacity-80"
      style="background:#2A1A10;color:#FFF8F1"
    >
      The Sunday Drop
    </a>
  </div>
</header>
