---
import Base from "../layouts/Base.astro";
---

<Base
  title="Page not found"
  description="The page you're looking for doesn't exist."
>
  <section class="max-w-readable mx-auto px-5 md:px-8 py-24 text-center">
    <div class="font-display text-7xl font-bold text-sun-600 tracking-tighter mb-4">
      404
    </div>
    <h1 class="font-display text-3xl font-bold text-ink-900 tracking-tight mb-3">
      Lost in the sun.
    </h1>
    <p class="text-ink-500 mb-8 max-w-md mx-auto">
      That page doesn't exist — maybe it moved, or maybe we wrote it wrong.
      Start with the full sunscreen ranking instead.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-1.5 text-sm font-medium bg-ink-900 text-cream-50 hover:bg-sun-700 transition-colors px-5 py-2.5 rounded-full"
    >
      See the 8 best Korean sunscreens →
    </a>
  </section>
</Base>
