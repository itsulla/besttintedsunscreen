---
import Base from "../../layouts/Base.astro";
import Schema from "../../components/Schema.astro";
import AffiliateLink from "../../components/AffiliateLink.astro";
import GlowOrb from "../../components/ui/GlowOrb.astro";
import Stars from "../../components/ui/Stars.astro";
import Divider from "../../components/ui/Divider.astro";
import { AFFILIATE } from "../../data/affiliate.ts";
import { PRODUCTS } from "../../data/products.ts";
import { reviewSchema } from "../../lib/schema.ts";
import type { Product } from "../../data/products.ts";

export async function getStaticPaths() {
  return PRODUCTS.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

interface Props {
  product: Product;
}
const { product: p } = Astro.props;

const affiliateUrl = AFFILIATE[p.affiliateKey]?.amazon ?? "#";

const title = `${p.brand} ${p.name} Review — Is It Worth It?`;
const description = `${p.tagline}. ${p.notes} SPF: ${p.spf}. Finish: ${p.finish}. Best for ${p.best}.`;

const schemaData = reviewSchema({
  productName: `${p.brand} ${p.name}`,
  brand: p.brand,
  image: p.image ?? "",
  description: p.notes,
  rating: p.rating,
  reviewBody: p.notes,
  datePublished: "2026-04-01",
  url: `/reviews/${p.slug}/`,
  offers: {
    price: p.price,
    url: affiliateUrl,
  },
});
---

<Base title={title} description={description}>
  <Schema data={[schemaData]} />

  <div class="relative min-h-screen overflow-x-hidden" style="background:#FFF8F1;color:#2A1A10">

    <!-- Background orbs -->
    <GlowOrb size={900} color="#E8B088" opacity={0.28} class="top-0 right-0" style="transform:translate(30%,-30%)" />
    <GlowOrb size={600} color="#D4A15E" opacity={0.18} class="top-[60%] left-0" style="transform:translate(-40%,0)" />

    <div class="relative z-10">

      <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
      <section class="px-6 md:px-16 pt-6 pb-20 grid md:grid-cols-5 gap-10 md:gap-12 max-w-glow mx-auto">

        <!-- Left col (3): hero image + glow + product photo -->
        <div class="md:col-span-3 flex items-center justify-center relative min-h-[400px] md:min-h-[700px] order-2 md:order-1">
          <!-- Radial glow backdrop -->
          <div
            class="absolute inset-0 flex items-center justify-center pointer-events-none"
          >
            <div
              class="w-[340px] md:w-[520px] h-[340px] md:h-[520px] rounded-full"
              style="background:radial-gradient(circle,#E8B08866 0%,transparent 65%)"
            ></div>
          </div>

          <!-- Swatch hero image -->
          <img
            src="/hero-swatch.png"
            alt="Golden-hour sunscreen swatch"
            class="relative rounded-[28px] object-cover w-full"
            style="max-height:640px;box-shadow:0 40px 80px -20px #2A1A1022"
            loading="eager"
          />

          <!-- Product image overlaid -->
          {p.image && (
            <img
              src={p.image}
              alt={`${p.brand} ${p.name}`}
              class="absolute right-0 bottom-10 w-24 md:w-40 h-36 md:h-64 object-contain"
              loading="eager"
            />
          )}
        </div>

        <!-- Right col (2): product info -->
        <div class="md:col-span-2 flex flex-col justify-center order-1 md:order-2 pt-4 md:pt-0">
          <!-- Eyebrow -->
          <p class="text-[11px] tracking-[0.4em] uppercase font-semibold mb-4" style="color:#D4A15E">
            Editor's Pick · Spring 2026
          </p>

          <!-- Brand -->
          <p class="text-sm tracking-[0.25em] uppercase mb-2" style="color:#A07860">{p.brand}</p>

          <!-- Product name headline -->
          <h1 class="font-dmserif font-normal leading-[0.9] mb-6" style="font-size:clamp(48px,6vw,72px)">
            {p.name.split(":")[0]}{p.name.includes(":") && ":"}<br />
            {p.name.includes(":") && (
              <span class="italic" style="color:#D89680">{p.name.split(":")[1]?.trim()}.</span>
            )}
            {!p.name.includes(":") && "."}
          </h1>

          <!-- Stars + count -->
          <div class="flex items-center gap-3 mb-6">
            <Stars rating={p.rating} color="#D4A15E" size={18} />
            <span class="text-sm" style="color:#A07860">{p.rating} · {p.reviews}</span>
          </div>

          <!-- Notes -->
          <p class="text-lg leading-relaxed mb-8" style="color:#2A1A10">{p.notes}</p>

          <!-- Spec rows -->
          <div class="space-y-0 mb-8 text-sm">
            {[["Protection", p.spf], ["Finish", p.finish], ["Best for", p.best]].map(([k, v]) => (
              <div class="flex justify-between py-3" style="border-bottom:1px solid #E8B08844">
                <span style="color:#A07860">{k}</span>
                <span style="color:#2A1A10;font-weight:500">{v}</span>
              </div>
            ))}
          </div>

          <!-- Price + CTA -->
          <div class="flex items-center gap-4">
            <span class="font-dmserif font-normal" style="font-size:48px;color:#2A1A10;line-height:1">
              {p.price}
            </span>
            <AffiliateLink
              href={affiliateUrl}
              class="flex-1 py-4 rounded-full text-xs tracking-[0.3em] uppercase font-medium text-center transition-opacity hover:opacity-80"
              style="background:#2A1A10;color:#FFF8F1"
            >
              Shop on Amazon →
            </AffiliateLink>
          </div>
        </div>
      </section>

      <!-- ─── PROS / CONS ────────────────────────────────────────────────────── -->
      <section class="px-6 md:px-16 py-16 grid md:grid-cols-2 gap-12 max-w-glow mx-auto" style="background:#FFF2E5">
        <!-- What we love -->
        <div>
          <p class="text-[11px] tracking-[0.4em] uppercase font-semibold mb-6" style="color:#D89680">
            What we love
          </p>
          <ul class="space-y-4">
            {p.pros.map((pro) => (
              <li class="font-dmserif font-normal text-2xl leading-snug">
                <span style="color:#D4A15E;margin-right:12px">+</span>{pro}
              </li>
            ))}
          </ul>
        </div>

        <!-- Worth knowing -->
        <div>
          <p class="text-[11px] tracking-[0.4em] uppercase font-semibold mb-6" style="color:#A07860">
            Worth knowing
          </p>
          <ul class="space-y-4">
            {p.cons.map((con) => (
              <li class="font-dmserif font-normal text-2xl leading-snug">
                <span style="color:#E8B088;margin-right:12px">−</span>{con}
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ─── WHAT SHOPPERS SAY ────────────────────────────────────────────── -->
      {(p.quotePositive || p.quoteCritical) && (
        <section class="px-6 md:px-16 py-16 max-w-glow mx-auto">
          <p class="text-[11px] tracking-[0.4em] uppercase font-semibold mb-10 text-center" style="color:#D4A15E">
            Real shoppers say
          </p>
          <div class="grid md:grid-cols-2 gap-8">

            {p.quotePositive && (
              <div class="rounded-[20px] p-8" style="background:#FFF2E5;border:1px solid #E8B08833">
                <!-- Star row -->
                <div class="flex items-center gap-1 mb-4">
                  {Array.from({ length: p.quotePositive.stars }).map(() => (
                    <svg width="14" height="14" viewBox="0 0 24 24">
                      <path d="M12 2 L15 9 L22 9.5 L17 14.5 L18.5 22 L12 18 L5.5 22 L7 14.5 L2 9.5 L9 9 Z" fill="#D4A15E" stroke="#D4A15E" stroke-width="1" />
                    </svg>
                  ))}
                </div>
                <blockquote class="text-base leading-relaxed mb-6" style="color:#2A1A10">
                  &ldquo;{p.quotePositive.text}&rdquo;
                </blockquote>
                <footer class="text-xs tracking-[0.2em] uppercase" style="color:#A07860">
                  — {p.quotePositive.reviewer} · {p.quotePositive.context} · {p.quotePositive.source}
                </footer>
              </div>
            )}

            {p.quoteCritical && (
              <div class="rounded-[20px] p-8" style="background:#FFF8F1;border:1px solid #E8B08833">
                <!-- Star row -->
                <div class="flex items-center gap-1 mb-4">
                  {Array.from({ length: p.quoteCritical.stars }).map(() => (
                    <svg width="14" height="14" viewBox="0 0 24 24">
                      <path d="M12 2 L15 9 L22 9.5 L17 14.5 L18.5 22 L12 18 L5.5 22 L7 14.5 L2 9.5 L9 9 Z" fill="#D4A15E" stroke="#D4A15E" stroke-width="1" />
                    </svg>
                  ))}
                  {Array.from({ length: 5 - p.quoteCritical.stars }).map(() => (
                    <svg width="14" height="14" viewBox="0 0 24 24">
                      <path d="M12 2 L15 9 L22 9.5 L17 14.5 L18.5 22 L12 18 L5.5 22 L7 14.5 L2 9.5 L9 9 Z" fill="none" stroke="#D4A15E" stroke-width="1" />
                    </svg>
                  ))}
                </div>
                <blockquote class="text-base leading-relaxed mb-6" style="color:#2A1A10">
                  &ldquo;{p.quoteCritical.text}&rdquo;
                </blockquote>
                <footer class="text-xs tracking-[0.2em] uppercase" style="color:#A07860">
                  — {p.quoteCritical.reviewer} · {p.quoteCritical.context} · {p.quoteCritical.source}
                </footer>
              </div>
            )}

          </div>
        </section>
      )}

      <!-- ─── VERDICT ────────────────────────────────────────────────────────── -->
      <section class="px-6 md:px-16 py-20 text-center max-w-glow mx-auto">
        <p class="text-[11px] tracking-[0.4em] uppercase font-semibold mb-4" style="color:#D4A15E">
          The Verdict
        </p>
        <blockquote
          class="font-dmserif font-normal italic max-w-3xl mx-auto leading-tight"
          style="font-size:clamp(28px,4vw,48px)"
        >
          "{p.tagline}."
        </blockquote>
        <p class="mt-6 text-xs tracking-[0.3em] uppercase" style="color:#A07860">
          — {p.best} · {p.origin}
        </p>

        <div class="mt-10">
          <AffiliateLink
            href={affiliateUrl}
            class="inline-block px-10 py-4 rounded-full text-xs tracking-[0.3em] uppercase font-medium transition-opacity hover:opacity-80"
            style="background:#2A1A10;color:#FFF8F1"
          >
            Shop {p.price} on Amazon →
          </AffiliateLink>
        </div>
      </section>

      <Divider color="#E8B088" class="max-w-5xl mx-auto px-6 md:px-16" />

      <!-- ─── NAV BACK ────────────────────────────────────────────────────────── -->
      <div class="text-center py-12">
        <a
          href="/#ranking"
          class="text-xs tracking-[0.3em] uppercase font-medium transition-opacity hover:opacity-60"
          style="color:#A07860"
        >
          ← Back to the full ranking
        </a>
      </div>

    </div>
  </div>
</Base>
