---
import Base from "../layouts/Base.astro";
import Schema from "../components/Schema.astro";
import AffiliateLink from "../components/AffiliateLink.astro";
import FAQ from "../components/FAQ.astro";
import GlowOrb from "../components/ui/GlowOrb.astro";
import Stars from "../components/ui/Stars.astro";
import Divider from "../components/ui/Divider.astro";
import { AFFILIATE } from "../data/affiliate.ts";
import { PRODUCTS } from "../data/products.ts";
import { NEWSLETTER } from "../data/newsletter.ts";
import { itemListSchema, faqSchema } from "../lib/schema.ts";

const title = "Best Tinted Sunscreens 2026 — 9 Picks Tested & Ranked";
const description =
  "9 best tinted sunscreens tested on real skin in 2026. Beauty of Joseon, ILIA, EltaMD, La Roche-Posay, MERIT, Numbuzin, Live Tinted — no white cast, ranked for every skin type.";

const faqItems = [
  {
    q: 'What is a "no white cast" sunscreen?',
    a: "Most Western mineral sunscreens leave a chalky white film because they rely on large zinc oxide particles. Korean formulas use micronised zinc and advanced chemical filters (like Tinosorb S and Uvinul A Plus) that absorb into the skin invisibly. <a href='/guides/what-is-no-white-cast-sunscreen/'>Full guide here →</a>",
  },
  {
    q: "Why are Korean sunscreens better than American ones?",
    a: "They're not always better, but they have access to UV filters the FDA hasn't approved since 1999. Tinosorb S and Uvinul A Plus are more photostable, more elegant, and more effective against UVA. That's the real edge — newer chemistry.",
  },
  {
    q: "Can I wear a tinted sunscreen under makeup?",
    a: "Yes — tinted sunscreens like Merit The Uniform and BoJ Relief Sun are designed to replace your primer + foundation on low-effort days, or work as a base on full-makeup days. Look for a satin or natural finish, not dewy, if you layer powder on top.",
  },
  {
    q: "Best Korean sunscreen for sensitive skin?",
    a: "Skin1004 Madagascar Centella Sunscreen is the go-to — it pairs SPF50+ PA++++ with centella asiatica, which calms redness. Beauty of Joseon Relief Sun Rice is also fragrance-free and tolerated by reactive skin.",
  },
  {
    q: "Are these available in Australia / UK / Canada?",
    a: "Yes — all nine products ship internationally through Amazon, iHerb, StyleKorean and YesStyle. We've put together regional buying guides: <a href='/guides/best-korean-sunscreen-australia/'>Australia edition →</a>",
  },
  {
    q: "How much sunscreen should I actually apply?",
    a: "Two finger-lengths for your face and neck. This is the amount needed to hit the SPF on the label — most people apply a third of that, which drops SPF50 to roughly SPF15 in practice. Reapply every 2 hours outdoors.",
  },
];

const itemListData = itemListSchema(
  "The 9 Best Tinted Sunscreens 2026",
  PRODUCTS.map((p) => ({
    name: `${p.brand} ${p.name}`,
    brand: p.brand,
    image: p.image ?? "",
    description: p.notes,
    url: `/reviews/${p.slug}/`,
  }))
);

const faqData = faqSchema(
  faqItems.map((item) => ({
    q: item.q,
    a: item.a.replace(/<[^>]+>/g, "").replace(/\s+/g, " ").trim(),
  }))
);

const isConfigured = NEWSLETTER.actionUrl?.length > 0;
---

<Base title={title} description={description}>
  <Schema data={[itemListData, faqData]} />

  <!-- Page background + signature glow orbs -->
  <div class="relative min-h-screen overflow-x-hidden" style="background:#FFF8F1;color:#2A1A10">

    <!-- Top-right accent orb -->
    <GlowOrb
      size={900}
      color="#E8B088"
      opacity={0.33}
      class="top-0 right-0"
      style="transform:translate(30%,-30%)"
    />
    <!-- Mid-left gold orb -->
    <GlowOrb
      size={700}
      color="#D4A15E"
      opacity={0.2}
      class="top-[40%] left-0"
      style="transform:translate(-40%,0)"
    />

    <div class="relative z-10">

      <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
      <section class="px-6 md:px-16 pt-20 md:pt-24 pb-16 md:pb-20 text-center relative">
        <!-- Eyebrow -->
        <p class="text-[11px] tracking-[0.5em] uppercase font-semibold mb-8" style="color:#D4A15E">
          Golden hour, every hour
        </p>

        <!-- Headline -->
        <h1
          class="mx-auto max-w-5xl leading-[0.9] tracking-tight font-dmserif font-normal"
          style="font-size:clamp(56px,10vw,140px)"
        >
          Wear the sun.<br />
          <span class="italic" style="color:#D89680">Not the damage.</span>
        </h1>

        <!-- Subtitle -->
        <p class="mt-10 max-w-xl mx-auto text-lg leading-relaxed" style="color:#A07860">
          We test every tinted sunscreen that matters — on real skin, over real weeks,
          through real humidity and real makeup. Here's what's actually worth wearing.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#ranking"
            class="px-8 py-4 rounded-full text-xs tracking-[0.3em] uppercase font-medium transition-opacity hover:opacity-80"
            style="background:#2A1A10;color:#FFF8F1"
          >
            See the Ranking
          </a>
          <a
            href="/quiz/"
            class="px-8 py-4 rounded-full text-xs tracking-[0.3em] uppercase font-medium transition-opacity hover:opacity-80"
            style="border:1px solid #2A1A10;color:#2A1A10"
          >
            Take the Quiz
          </a>
        </div>

        <!-- Hero image with radial glow bloom -->
        <div class="mt-14 relative mx-auto" style="max-width:1100px">
          <div
            class="absolute inset-0 rounded-[40px] pointer-events-none"
            style="background:radial-gradient(ellipse at 50% 40%,#E8B08866 0%,transparent 65%);transform:scale(1.2)"
          ></div>
          <img
            src="/hero-swatch.png"
            alt="Creamy tinted sunscreen swatch on peach silk in golden-hour light"
            class="relative w-full object-cover"
            style="border-radius:32px;max-height:620px;box-shadow:0 40px 80px -20px #2A1A1022"
            loading="eager"
          />
        </div>
      </section>

      <!-- ─── STATS ROW ──────────────────────────────────────────────────────── -->
      <section class="px-6 md:px-16 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-5xl mx-auto text-center">
          {[
            { t: "47",   s: "products tested" },
            { t: "14d",  s: "per product, minimum" },
            { t: "100%", s: "independently bought" },
            { t: "$0",   s: "paid placements, ever" },
          ].map(({ t, s }) => (
            <div>
              <div class="font-dmserif font-normal mb-2" style="font-size:60px;color:#D4A15E;line-height:1">
                {t}
              </div>
              <div class="text-xs tracking-[0.25em] uppercase" style="color:#A07860">{s}</div>
            </div>
          ))}
        </div>
      </section>

      <Divider color="#E8B088" class="max-w-5xl mx-auto px-6 md:px-16" />

      <!-- ─── RANKING ─────────────────────────────────────────────────────────── -->
      <section id="ranking" class="px-6 md:px-16 py-20">
        <!-- Section heading -->
        <div class="text-center mb-16">
          <p class="text-[11px] tracking-[0.4em] uppercase font-semibold mb-3" style="color:#D4A15E">
            The 2026 Ranking
          </p>
          <h2 class="font-dmserif font-normal" style="font-size:clamp(40px,6vw,72px)">
            The <span class="italic" style="color:#D89680">nine</span> we wear.
          </h2>
        </div>

        <!-- Editorial list -->
        <div class="max-w-5xl mx-auto">
          {PRODUCTS.map((p) => {
            const href = AFFILIATE[p.affiliateKey]?.amazon ?? "#";
            return (
              <article
                class="grid grid-cols-12 gap-4 md:gap-6 items-center py-6 transition-all duration-200 hover:px-4"
                style="border-top:1px solid #E8B08844"
              >
                <!-- Rank -->
                <div class="col-span-2 md:col-span-1 relative">
                  <span class="font-dmserif font-normal text-5xl md:text-6xl leading-none" style="color:#D4A15E">
                    {p.rank < 10 ? `0${p.rank}` : p.rank}
                  </span>
                  {p.rank >= 6 && (
                    <span
                      class="absolute -top-1 -right-1 text-[8px] font-semibold uppercase tracking-wider px-1.5 py-0.5 rounded-full"
                      style="background:#D4A15E;color:#FFF8F1;line-height:1.4"
                    >
                      NEW
                    </span>
                  )}
                </div>

                <!-- Product image -->
                <div class="col-span-2 flex justify-center">
                  {p.image ? (
                    <img
                      src={p.image}
                      alt={`${p.brand} ${p.name}`}
                      class="w-16 md:w-20 h-24 md:h-32 object-contain"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-16 md:w-20 h-24 md:h-32 rounded-2xl" style={`background:${p.color}`}></div>
                  )}
                </div>

                <!-- Brand + name + notes -->
                <div class="col-span-8 md:col-span-5">
                  <p class="text-[10px] tracking-[0.3em] uppercase font-semibold mb-1" style="color:#D89680">
                    {p.tagline}
                  </p>
                  <h3 class="font-dmserif font-normal text-2xl md:text-3xl mb-2">
                    {p.brand}: <span class="italic">{p.name}</span>
                  </h3>
                  <p class="text-sm leading-relaxed max-w-md hidden md:block" style="color:#A07860">
                    {p.notes}
                  </p>
                </div>

                <!-- Specs + stars -->
                <div class="col-span-6 md:col-span-2 text-sm" style="color:#A07860">
                  <p>{p.spf}</p>
                  <p>{p.finish}</p>
                  <div class="mt-2">
                    <Stars rating={p.rating} color="#D4A15E" size={12} />
                  </div>
                </div>

                <!-- Price + Shop -->
                <div class="col-span-6 md:col-span-2 text-right">
                  <p class="font-dmserif font-normal text-2xl md:text-3xl mb-2" style="color:#2A1A10">
                    {p.price}
                  </p>
                  <AffiliateLink
                    href={href}
                    class="text-[10px] tracking-[0.3em] uppercase underline font-medium transition-opacity hover:opacity-60"
                    style="color:#2A1A10"
                  >
                    Shop →
                  </AffiliateLink>
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <Divider color="#E8B088" class="max-w-5xl mx-auto px-6 md:px-16" />

      <!-- ─── NEWSLETTER ─────────────────────────────────────────────────────── -->
      <section id="newsletter" class="px-6 md:px-16 py-24 relative">
        <div
          class="max-w-4xl mx-auto p-10 md:p-16 text-center relative overflow-hidden"
          style="background:linear-gradient(135deg,#FFF2E5,#FFEFE0);border-radius:28px"
        >
          <!-- Gold glow orb bleeding off top-right -->
          <div
            class="absolute -top-20 -right-20 w-64 h-64 rounded-full pointer-events-none"
            style="background:radial-gradient(circle,#D4A15E88,transparent 70%)"
          ></div>

          <div class="relative">
            <p class="text-[11px] tracking-[0.4em] uppercase font-semibold mb-4" style="color:#D4A15E">
              The Sunday Drop
            </p>
            <h2 class="font-dmserif font-normal mb-5" style="font-size:clamp(36px,5vw,60px)">
              One email,{" "}
              <span class="italic" style="color:#D89680">every Sunday.</span>
            </h2>
            <p class="text-base max-w-md mx-auto mb-8" style="color:#A07860">
              New launches. Restock alerts. Quiet sales. Whatever's rising in Korean skincare right now.
            </p>

            <form
              action={NEWSLETTER.actionUrl || "#"}
              method="post"
              class="flex flex-col sm:flex-row max-w-md mx-auto gap-2"
            >
              <input
                type="email"
                name={NEWSLETTER.emailFieldName}
                required
                placeholder="you@email.com"
                class="flex-1 px-6 py-4 rounded-full text-sm focus:outline-none"
                style="background:#fff;border:1px solid #E8B08866"
              />
              {Object.entries(NEWSLETTER.hiddenFields ?? {}).map(([name, value]) => (
                <input type="hidden" name={name} value={value} />
              ))}
              <button
                type="submit"
                disabled={!isConfigured}
                class="px-8 py-4 rounded-full text-xs tracking-[0.3em] uppercase font-medium transition-opacity hover:opacity-80 disabled:opacity-50"
                style="background:#2A1A10;color:#FFF8F1"
              >
                Join
              </button>
            </form>

            <p class="mt-4 text-xs" style="color:#A07860">
              One email a week. Unsubscribe in one click.
            </p>
          </div>
        </div>
      </section>

      <!-- ─── FAQ ───────────────────────────────────────────────────────────── -->
      <section class="max-w-3xl mx-auto px-6 md:px-8 pb-20">
        <h2 class="font-dmserif font-normal text-center mb-10" style="font-size:clamp(32px,4vw,48px)">
          Questions we get asked.
        </h2>
        <FAQ items={faqItems} />
      </section>

      <!-- ─── FOOTER ─────────────────────────────────────────────────────────── -->
      <footer
        class="px-6 md:px-16 py-10 text-xs text-center"
        style="color:#A07860;border-top:1px solid #E8B08833"
      >
        <p>© 2026 BestTintedSunscreen.com</p>
        <p class="mt-2 max-w-prose mx-auto">
          As an Amazon Associate we earn from qualifying purchases. All products
          independently bought and tested — zero paid placements, ever.
        </p>
      </footer>

    </div>
  </div>
</Base>
